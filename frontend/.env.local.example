# Frontend environment variables — copy to .env.local and fill in
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=constituency-priorities
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://constituency-priorities-default-rtdb.firebaseio.com
