# Backend environment variables — copy to .env.local and fill in
GCP_PROJECT=constituency-priorities
BQ_DATASET=constituency_data
GCS_BUCKET=constituency-uploads
GCP_REGION=asia-south1

GEMINI_API_KEY=your_gemini_api_key
VERTEX_EMBEDDING_MODEL=text-embedding-005

FIREBASE_CREDENTIALS_PATH=/path/to/firebase-adminsdk.json
FIREBASE_DB_URL=https://constituency-priorities-default-rtdb.firebaseio.com

TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

MAPS_API_KEY=your_google_maps_api_key

ENVIRONMENT=development
PILOT_CONSTITUENCY=Hyderabad
PILOT_STATE=Telangana
