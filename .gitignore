# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# ─── Secrets / Keys (NEVER commit) ──────────────────────────────────────────
*.pem
*.key
service-account*.json
gcp-credentials*.json
firebase-adminsdk*.json
*secret*
*credentials*

# ─── Node / Next.js ──────────────────────────────────────────────────────────
node_modules/
.next/
out/
frontend/.env
frontend/.env.local
frontend/.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Terraform ───────────────────────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfvars
infra/terraform/override.tf
infra/terraform/crash.log

# ─── IDEs / OS ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── Pytest / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── Data (large files — use git-lfs or keep out of repo) ───────────────────
# Comment out if you want to track small CSVs under version control
# data/public-datasets/*.csv

# ─── Misc ────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
